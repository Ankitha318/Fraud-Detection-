        "# Cell 7: TASK 5 - Generate dashboard data\n",
        "print(\"=\" * 55)\n",
        "print(\"TASK 5: DOCUMENT RESULTS\")\n",
        "print(\"=\" * 55)\n",
        "\n",
        "import json\n",
        "\n",
        "# Confusion matrix for best model\n",
        "from pyspark.mllib.evaluation import MulticlassMetrics\n",
        "from pyspark.sql.functions import col\n",
        "\n",
        "pred_and_labels = best_preds.select(\n",
        "    col(\"prediction\").cast(\"double\"),\n",
        "    col(\"label\").cast(\"double\")\n",
        ").rdd.map(lambda x: (x[0], x[1]))\n",
        "\n",
        "metrics = MulticlassMetrics(pred_and_labels)\n",
        "cm = metrics.confusionMatrix().toArray()\n",
        "\n",
        "TP = int(cm[1][1]); FP = int(cm[0][1])\n",
        "TN = int(cm[0][0]); FN = int(cm[1][0])\n",
        "precision = TP / (TP + FP) if (TP+FP) > 0 else 0\n",
        "recall    = TP / (TP + FN) if (TP+FN) > 0 else 0\n",
        "\n",
        "dashboard_data = {\n",
        "    \"dataset\": {\n",
        "        \"total\": int(total),\n",
        "        \"legitimate\": int(legit_count),\n",
        "        \"fraudulent\": int(fraud_count),\n",
        "        \"fraud_pct\": round(fraud_count/total*100, 3)\n",
        "    },\n",
        "    \"models\": results,\n",
        "    \"best_model\": best_model_name,\n",
        "    \"confusion_matrix\": {\"TP\": TP, \"FP\": FP, \"TN\": TN, \"FN\": FN},\n",
