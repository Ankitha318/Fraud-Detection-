      "cell_type": "code",
      "source": [
        "# Cell 5: TASK 3 - PySpark Optimizations\n",
        "print(\"=\" * 55)\n",
        "print(\"TASK 3: PYSPARK OPTIMIZATIONS\")\n",
        "print(\"=\" * 55)\n",
        "\n",
        "from pyspark.sql.functions import col, log1p\n",
        "from pyspark.ml.feature import VectorAssembler, StandardScaler\n",
        "\n",
        "# 1. Repartition\n",
        "df_optimized = df.repartition(8)\n",
        "print(f\"✅ Opt 1: Repartitioned → {df_optimized.rdd.getNumPartitions()} partitions\")\n",
        "\n",
        "# 2. Feature engineering\n",
        "df_optimized = df_optimized \\\n",
        "    .withColumn(\"Amount_log\", log1p(col(\"Amount\"))) \\\n",
        "    .withColumn(\"Time_norm\", col(\"Time\") / 3600)\n",
        "print(\"✅ Opt 2: Log-scaled Amount, normalized Time to hours\")\n",
        "\n",
        "# 3. Feature columns\n",
        "feature_cols = [f\"V{i}\" for i in range(1, 29)] + [\"Amount_log\", \"Time_norm\"]\n",
        "print(f\"✅ Opt 3: {len(feature_cols)} features selected\")\n",
        "\n",
        "# 4. Assemble features\n",
        "assembler = VectorAssembler(inputCols=feature_cols, outputCol=\"features\")\n",
        "df_assembled = assembler.transform(df_optimized)\n",
        "\n",
        "# 5. Standard scaling\n",
        "scaler = StandardScaler(inputCol=\"features\", outputCol=\"scaled_features\",\n",
        "                        withStd=True, withMean=True)\n",
        "scaler_model = scaler.fit(df_assembled)\n",
        "df_scaled = scaler_model.transform(df_assembled)\n",
        "\n",
        "# 6. Rename & cache\n",
        "df_scaled = df_scaled.withColumnRenamed(\"Class\", \"label\")\n",
        "df_scaled.cache()\n",
        "\n",
        "print(\"✅ Opt 4: StandardScaler applied\")\n",
        "print(\"✅ Opt 5: DataFrame cached in memory\")\n",
        "print(f\"\\n📊 Final dataset: {df_scaled.count():,} rows ready for training\")"
      ],
