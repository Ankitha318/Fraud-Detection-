      "source": [
        "# Cell 6: TASK 4 - Train models and validate\n",
        "print(\"=\" * 55)\n",
        "print(\"TASK 4: MODEL TRAINING & VALIDATION\")\n",
        "print(\"=\" * 55)\n",
        "\n",
        "from pyspark.ml.classification import LogisticRegression, RandomForestClassifier, GBTClassifier\n",
        "from pyspark.ml.evaluation import BinaryClassificationEvaluator, MulticlassClassificationEvaluator\n",
        "from pyspark.ml import Pipeline\n",
        "import time\n",
        "\n",
        "# Train/test split\n",
        "train_df, test_df = df_scaled.randomSplit([0.8, 0.2], seed=42)\n",
        "train_df.cache()\n",
        "test_df.cache()\n",
        "\n",
        "print(f\"📦 Train: {train_df.count():,} | Test: {test_df.count():,}\")\n",
        "\n",
        "evaluator_auc  = BinaryClassificationEvaluator(labelCol=\"label\", metricName=\"areaUnderROC\")\n",
        "evaluator_pr   = BinaryClassificationEvaluator(labelCol=\"label\", metricName=\"areaUnderPR\")\n",
        "evaluator_f1   = MulticlassClassificationEvaluator(labelCol=\"label\", metricName=\"f1\")\n",
        "evaluator_acc  = MulticlassClassificationEvaluator(labelCol=\"label\", metricName=\"accuracy\")\n",
        "\n",
        "results = {}\n",
        "\n",
        "# --- Model 1: Logistic Regression ---\n",
        "print(\"\\n🔄 Training Logistic Regression...\")\n",
        "t0 = time.time()\n",
        "lr = LogisticRegression(featuresCol=\"scaled_features\", labelCol=\"label\",\n",
        "                        maxIter=20, regParam=0.01)\n",
        "lr_model = lr.fit(train_df)\n",
        "lr_preds = lr_model.transform(test_df)\n",
        "results[\"Logistic Regression\"] = {\n",
        "    \"AUC-ROC\" : evaluator_auc.evaluate(lr_preds),\n",
        "    \"AUC-PR\"  : evaluator_pr.evaluate(lr_preds),\n",
        "    \"F1\"      : evaluator_f1.evaluate(lr_preds),\n",
        "    \"Accuracy\": evaluator_acc.evaluate(lr_preds),\n",
        "    \"Time(s)\" : round(time.time() - t0, 2)\n",
        "}\n",
        "print(f\"   ✅ AUC-ROC: {results['Logistic Regression']['AUC-ROC']:.4f}\")\n",
        "\n",
        "# --- Model 2: Random Forest ---\n",
        "print(\"\\n🔄 Training Random Forest...\")\n",
        "t0 = time.time()\n",
        "rf = RandomForestClassifier(featuresCol=\"scaled_features\", labelCol=\"label\",\n",
        "                             numTrees=50, maxDepth=10, seed=42)\n",
        "rf_model = rf.fit(train_df)\n",
        "rf_preds = rf_model.transform(test_df)\n",
        "results[\"Random Forest\"] = {\n",
        "    \"AUC-ROC\" : evaluator_auc.evaluate(rf_preds),\n",
        "    \"AUC-PR\"  : evaluator_pr.evaluate(rf_preds),\n",
        "    \"F1\"      : evaluator_f1.evaluate(rf_preds),\n",
        "    \"Accuracy\": evaluator_acc.evaluate(rf_preds),\n",
        "    \"Time(s)\" : round(time.time() - t0, 2)\n",
        "}\n",
        "print(f\"   ✅ AUC-ROC: {results['Random Forest']['AUC-ROC']:.4f}\")\n",
        "\n",
        "# --- Model 3: GBT ---\n",
        "print(\"\\n🔄 Training Gradient Boosted Trees...\")\n",
        "t0 = time.time()\n",
        "gbt = GBTClassifier(featuresCol=\"scaled_features\", labelCol=\"label\",\n",
        "                    maxIter=30, maxDepth=5, seed=42)\n",
        "gbt_model = gbt.fit(train_df)\n",
        "gbt_preds = gbt_model.transform(test_df)\n",
        "results[\"GBT\"] = {\n",
        "    \"AUC-ROC\" : evaluator_auc.evaluate(gbt_preds),\n",
        "    \"AUC-PR\"  : evaluator_pr.evaluate(gbt_preds),\n",
        "    \"F1\"      : evaluator_f1.evaluate(gbt_preds),\n",
        "    \"Accuracy\": evaluator_acc.evaluate(gbt_preds),\n",
        "    \"Time(s)\" : round(time.time() - t0, 2)\n",
        "}\n",
        "print(f\"   ✅ AUC-ROC: {results['GBT']['AUC-ROC']:.4f}\")\n",
        "\n",
        "# Summary\n",
        "print(\"\\n\" + \"=\" * 55)\n",
        "print(f\"{'Model':<22} {'AUC-ROC':>8} {'AUC-PR':>8} {'F1':>8} {'Acc':>8} {'Time':>7}\")\n",
        "print(\"-\" * 55)\n",
        "for name, m in results.items():\n",
        "    print(f\"{name:<22} {m['AUC-ROC']:>8.4f} {m['AUC-PR']:>8.4f} {m['F1']:>8.4f} {m['Accuracy']:>8.4f} {m['Time(s)']:>6}s\")\n",
        "\n",
        "# Best model\n",
        "best_model_name = max(results, key=lambda k: results[k][\"AUC-ROC\"])\n",
